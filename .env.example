# AWS基本設定
AWS_REGION=us-east-1

# Bedrock モデル設定
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
AGENT_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0

# DynamoDB設定
DYNAMODB_TABLE_PREFIX=AIPersona
DYNAMODB_REGION=us-east-1

# S3設定（ファイルストレージ）
S3_BUCKET_NAME=your-bucket-name

# AgentCore Memory設定（長期記憶機能を使用する場合）
ENABLE_LONG_TERM_MEMORY=false
AGENTCORE_MEMORY_ID=your-memory-id
AGENTCORE_MEMORY_REGION=us-east-1
MEMORY_STRATEGY=summary
MEMORY_MAX_RESULTS=5
SUMMARY_MEMORY_STRATEGY_ID=your-summary-strategy-id
SEMANTIC_MEMORY_STRATEGY_ID=your-semantic-strategy-id

# マスアンケート機能設定
BATCH_INFERENCE_MODEL_ID=global.anthropic.claude-haiku-4-5-20251001-v1:0
BEDROCK_BATCH_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockBatchInferenceRole
SURVEY_S3_PREFIX=survey-results/
BATCH_INFERENCE_S3_PREFIX=batch-inference/
